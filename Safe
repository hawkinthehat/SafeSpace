<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>SafeSpace | Direct Access</title>
    <style>
        :root {
            --bg: #0a192f;
            --card: #112240;
            --teal: #64ffda;
            --red: #ff4d4d;
            --text: #ccd6f6;
        }

        body { 
            background: var(--bg); 
            color: var(--text); 
            font-family: sans-serif; 
            margin: 0; 
            display: flex;
            flex-direction: column;
            align-items: center;
            text-align: center;
        }

        .screen { display: none; width: 100%; max-width: 400px; padding: 40px 20px; box-sizing: border-box; flex-direction: column; align-items: center; }
        .active { display: flex; animation: fadeIn 0.3s; }
        @keyframes fadeIn { from { opacity: 0; } to { opacity: 1; } }

        h1 { color: var(--teal); margin-bottom: 30px; }
        
        .btn { 
            background: var(--card); 
            border: 1px solid var(--teal); 
            color: var(--teal); 
            padding: 20px; 
            border-radius: 15px; 
            width: 100%; 
            margin: 10px 0; 
            font-size: 1.1rem;
            font-weight: bold;
            cursor: pointer;
            text-decoration: none;
        }
        .btn-sos { background: var(--red); color: white; border: none; }

        /* THE BREATHER */
        .circle { width: 120px; height: 120px; background: var(--teal); border-radius: 50%; opacity: 0.3; animation: b 8s infinite; margin: 30px; }
        @keyframes b { 0%, 100% { transform: scale(0.8); } 50% { transform: scale(1.3); } }
    </style>
</head>
<body>

    <div id="home" class="screen active">
        <h1>SafeSpace</h1>
        <button class="btn btn-sos" onclick="show('sos')">SOS: PANIC ATTACK</button>
        <button class="btn" onclick="show('grounding')">5-4-3-2-1 Grounding</button>
        <button class="btn" onclick="show('icedive')">Ice Reset ❄️</button>
        <p style="margin-top:40px; opacity:0.5; font-size:0.8rem;">SafeSpace by Joe Ancheta Jr.</p>
    </div>

    <div id="sos" class="screen">
        <h2>Breathe</h2>
        <div class="circle"></div>
        <p>In for 4... Out for 4...</p>
        <button class="btn" onclick="show('home')">I'm Feeling Better</button>
    </div>

    <div id="grounding" class="screen">
        <h2>5-4-3-2-1</h2>
        <p style="font-size: 1.2rem; color: var(--teal);">Name 5 things you see.</p>
        <button class="btn" onclick="show('home')">Done</button>
    </div>

    <div id="icedive" class="screen">
        <h2>Ice Reset</h2>
        <p>Hold ice or splash cold water for 15 seconds.</p>
        <button class="btn" onclick="show('home')">Done</button>
    </div>

    <script>
        function show(id) {
            // Hide all screens
            document.querySelectorAll('.screen').forEach(s => {
                s.style.display = 'none';
            });
            // Show the selected one
            const target = document.getElementById(id);
            target.style.display = 'flex';
        }
    </script>
</body>
</html>
