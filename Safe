<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>SafeSpace | Joe Ancheta Jr.</title>
    <style>
        :root { --bg: #0a192f; --teal: #64ffda; --text: #ccd6f6; }
        body { background: var(--bg); color: var(--text); font-family: sans-serif; margin: 0; text-align: center; }
        .screen { display: none; padding: 40px; min-height: 80vh; flex-direction: column; align-items: center; justify-content: center; }
        .active { display: flex; }
        .btn { background: #112240; border: 1px solid var(--teal); color: var(--teal); padding: 20px; border-radius: 30px; width: 280px; margin: 10px; cursor: pointer; font-weight: bold; }
        #tutorial { position: fixed; inset: 0; background: var(--bg); z-index: 100; display: flex; flex-direction: column; align-items: center; justify-content: center; }
    </style>
</head>
<body>

    <div id="tutorial">
        <h1 style="color: var(--teal);">SafeSpace</h1>
        <p>Your digital weighted blanket.</p>
        <button class="btn" onclick="this.parentElement.style.display='none'">Enter App</button>
    </div>

    <div id="home" class="screen active">
        <h1>Welcome, Joe.</h1>
        <button class="btn" style="background: #ff4d4d; color: white; border: none;" onclick="show('sos')">SOS: PANIC</button>
        <button class="btn" onclick="show('grounding')">5-4-3-2-1 Grounding</button>
    </div>

    <div id="sos" class="screen">
        <h2>Breathe with the circle...</h2>
        <div style="width:100px; height:100px; background:var(--teal); border-radius:50%; opacity:0.5; margin: 20px;"></div>
        <button class="btn" onclick="show('home')">Back Home</button>
    </div>

    <div id="grounding" class="screen">
        <h2>5-4-3-2-1</h2>
        <p>Name 5 things you can see.</p>
        <button class="btn" onclick="show('home')">Back Home</button>
    </div>

    <script>
        function show(id) {
            document.querySelectorAll('.screen').forEach(s => s.classList.remove('active'));
            document.getElementById(id).classList.add('active');
        }
    </script>
</body>
</html>
